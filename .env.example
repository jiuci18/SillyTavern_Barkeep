# Optional API auth password
API_PASSWORD=password

# Optional path to main config json (default: data/config/main_conf.json)
BARKEEPER_CONFIG_PATH=data/config/main_conf.json

# true: use SillyTavern router mode
# false: start standalone HTTP server
HTTP_MODE=false

# Standalone HTTP listen address, used when HTTP_MODE=false
BARKEEPER_LISTEN=0.0.0.0:10024

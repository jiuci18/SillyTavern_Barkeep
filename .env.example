# Optional API auth password
API_PASSWORD=
API_PASSWORD_ENABLE=false
API_PASSWORD_FORCE=false

# JWT signing secret. Generate a strong random string (64+ characters recommended).
# If left empty, a new random secret is generated on every startup,
# invalidating all previously issued tokens.
JWT_SECRET=

# Required path to main config json, relative to the plugin root
BARKEEPER_CONFIG_PATH=data/config/main_conf.json

# Optional SillyTavern root override, relative to the plugin root or absolute.
# When empty, the plugin checks ../.. first and then walks up parent directories.
SILLYTAVERN_ROOT=

# true: start standalone HTTP server
# false: use SillyTavern router mode
HTTP_MODE=false

# Standalone HTTP listen address, used when HTTP_MODE=true
BARKEEPER_LISTEN=0.0.0.0:10024
